{
  "name": "chronhub/stream",
  "description": "stream",
  "keywords": [
    "stream"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "steph bug",
      "email": "chronhubgit@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "chronhub/contracts": "dev-main"
  },
  "require-dev": {
    "chronhub/message": "dev-main",
    "laravel/pint": "^0.2",
    "nunomaduro/larastan": "^2.1",
    "phpspec/prophecy-phpunit": "dev-master",
    "phpunit/phpunit": "^9.5",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Chronhub\\Stream\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Chronhub\\Stream\\Tests\\": "tests"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "pint": "vendor/bin/pint"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "minimum-stability": "dev"
}